rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── User profile photos ───────────────────────────────────────────────────
    // Only the user can write their own photo; any authenticated user can read
    // (needed so partner can see profile photo)
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Couple shared storage ─────────────────────────────────────────────────
    // Memories, Truth or Dare audio recordings
    // Firestore rules protect which coupleId is valid — here we just require auth
    match /couples/{coupleId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
