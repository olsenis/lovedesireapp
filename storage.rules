rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Check if requesting user is a member of the given couple
    function isMemberOfCouple(coupleId) {
      let couple = firestore.get(/databases/(default)/documents/couples/$(coupleId));
      return couple != null && (
        couple.data.partner1Uid == request.auth.uid ||
        couple.data.partner2Uid == request.auth.uid
      );
    }

    // ── User profile photos ───────────────────────────────────────────────────
    // Only the user can write their own photo; any authenticated user can read
    // (needed so partner can see profile photo)
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Couple shared storage ─────────────────────────────────────────────────
    // Memories, Truth or Dare audio — only couple members can read/write
    match /couples/{coupleId}/{allPaths=**} {
      allow read, write: if request.auth != null && isMemberOfCouple(coupleId);
    }
  }
}
