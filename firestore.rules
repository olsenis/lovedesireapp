rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Returns true if the requesting user is a member of the given couple
    function isMemberOfCouple(coupleId) {
      let couple = get(/databases/$(database)/documents/couples/$(coupleId));
      return couple != null && (
        couple.data.partner1Uid == request.auth.uid ||
        couple.data.partner2Uid == request.auth.uid
      );
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Any authenticated user can read basic profiles (needed for partner name/photo)
      allow read: if request.auth != null;
      // Only the user themselves can write their own profile
      allow write: if request.auth != null && request.auth.uid == uid;

      // Private subcollections (blueprint result, help state)
      match /private/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Couples ───────────────────────────────────────────────────────────────
    match /couples/{coupleId} {
      // Read: use resource.data directly (avoids circular get() call)
      allow read: if request.auth != null && (
        resource.data.partner1Uid == request.auth.uid ||
        resource.data.partner2Uid == request.auth.uid
      );

      // Create: user must be setting themselves as partner1Uid
      allow create: if request.auth != null
        && request.resource.data.partner1Uid == request.auth.uid;

      // Update: existing member, OR user is joining as partner2Uid for the first time
      allow update: if request.auth != null && (
        isMemberOfCouple(coupleId) ||
        (
          resource.data.get('partner2Uid', null) == null &&
          request.resource.data.partner2Uid == request.auth.uid
        )
      );

      // ── All subcollections under a couple ──────────────────────────────────
      // Todos, moods, memories, notes, wishlist, fantasy, fantasyWishes,
      // reminders, dates, challenge, blueprints, wyr, bingo, truthDare,
      // dailyWishes, dailyQuestions, streaks, sensate
      match /{subcollection}/{document=**} {
        allow read, write: if request.auth != null && isMemberOfCouple(coupleId);
      }
    }
  }
}
