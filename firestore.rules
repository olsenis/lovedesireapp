rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Returns true if the requesting user is a member of the given couple
    function isMemberOfCouple(coupleId) {
      let couple = get(/databases/$(database)/documents/couples/$(coupleId));
      return couple != null && (
        couple.data.partner1Uid == request.auth.uid ||
        couple.data.partner2Uid == request.auth.uid
      );
    }

    // Returns true if the requesting user is otherUid's current couple partner
    function isPartnerOf(otherUid) {
      let myCoupleId = get(/databases/$(database)/documents/users/$(request.auth.uid))
        .data.get('coupleId', '');
      return myCoupleId != '' &&
        (
          get(/databases/$(database)/documents/couples/$(myCoupleId)).data.partner1Uid == otherUid ||
          get(/databases/$(database)/documents/couples/$(myCoupleId)).data.partner2Uid == otherUid
        );
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Only the user themselves OR their current partner can read the profile.
      // Closes the leak where any authenticated user could read pushToken / birthday / etc.
      allow read: if request.auth != null && (
        request.auth.uid == uid || isPartnerOf(uid)
      );

      // Only the user themselves can write their own profile.
      allow write: if request.auth != null && request.auth.uid == uid;

      // Private subcollections: blueprint, consent, help, profile (birthday, push opt-in, etc.)
      // Strictly self-only.
      match /private/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Couples ───────────────────────────────────────────────────────────────
    match /couples/{coupleId} {
      // Read: use resource.data directly (avoids circular get() call)
      allow read: if request.auth != null && (
        resource.data.partner1Uid == request.auth.uid ||
        resource.data.partner2Uid == request.auth.uid
      );

      // Create: user must be setting themselves as partner1Uid
      allow create: if request.auth != null
        && request.resource.data.partner1Uid == request.auth.uid;

      // Update: existing member, OR user is joining as partner2Uid for the first time
      allow update: if request.auth != null && (
        isMemberOfCouple(coupleId) ||
        (
          resource.data.get('partner2Uid', null) == null &&
          request.resource.data.partner2Uid == request.auth.uid
        )
      );

      // ── Blueprint results: both partners can READ, only owner can WRITE ─────
      match /blueprints/{userId} {
        allow read: if request.auth != null && isMemberOfCouple(coupleId);
        allow write: if request.auth != null
          && request.auth.uid == userId
          && isMemberOfCouple(coupleId);
      }

      // ── All other subcollections under a couple ────────────────────────────
      // Schema validation: prevent spoofing of identity fields.
      // Any document the caller creates with these fields MUST have them set to themselves.
      // Reads + updates + deletes remain available to either couple member.
      match /{subcollection}/{document=**} {
        allow read: if request.auth != null && isMemberOfCouple(coupleId);
        allow create: if request.auth != null
          && isMemberOfCouple(coupleId)
          && (!('fromUid'   in request.resource.data) || request.resource.data.fromUid   == request.auth.uid)
          && (!('createdBy' in request.resource.data) || request.resource.data.createdBy == request.auth.uid)
          && (!('loggedBy'  in request.resource.data) || request.resource.data.loggedBy  == request.auth.uid)
          && (!('uid'       in request.resource.data) || request.resource.data.uid       == request.auth.uid);
        // Updates: identity fields are immutable once set
        allow update: if request.auth != null
          && isMemberOfCouple(coupleId)
          && (!('fromUid'   in resource.data) || request.resource.data.fromUid   == resource.data.fromUid)
          && (!('createdBy' in resource.data) || request.resource.data.createdBy == resource.data.createdBy)
          && (!('loggedBy'  in resource.data) || request.resource.data.loggedBy  == resource.data.loggedBy)
          && (!('uid'       in resource.data) || request.resource.data.uid       == resource.data.uid);
        allow delete: if request.auth != null && isMemberOfCouple(coupleId);
      }
    }
  }
}
