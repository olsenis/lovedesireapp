rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Returns true if the requesting user is a member of the given couple
    function isMemberOfCouple(coupleId) {
      let couple = get(/databases/$(database)/documents/couples/$(coupleId));
      return couple != null && (
        couple.data.partner1Uid == request.auth.uid ||
        couple.data.partner2Uid == request.auth.uid
      );
    }

    // Returns true if the requesting user is otherUid's current couple partner
    function isPartnerOf(otherUid) {
      let myCoupleId = get(/databases/$(database)/documents/users/$(request.auth.uid))
        .data.get('coupleId', '');
      return myCoupleId != '' &&
        (
          get(/databases/$(database)/documents/couples/$(myCoupleId)).data.partner1Uid == otherUid ||
          get(/databases/$(database)/documents/couples/$(myCoupleId)).data.partner2Uid == otherUid
        );
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Only the user themselves OR their current partner can read the profile.
      // Closes the leak where any authenticated user could read pushToken / birthday / etc.
      allow read: if request.auth != null && (
        request.auth.uid == uid || isPartnerOf(uid)
      );

      // User can write their own profile, but NOT isPremium — that field is set
      // server-side by the RevenueCat webhook (functions/src/index.ts). Without
      // this lock, any client could write isPremium: true and unlock the paid tier.
      allow write: if request.auth != null
        && request.auth.uid == uid
        && (
          !('isPremium' in request.resource.data)
          || request.resource.data.isPremium == resource.data.get('isPremium', false)
        );

      // Private subcollections: blueprint, consent, help, profile (birthday, push opt-in, etc.)
      // Strictly self-only.
      match /private/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Couples ───────────────────────────────────────────────────────────────
    match /couples/{coupleId} {
      // Read: use resource.data directly (avoids circular get() call)
      allow read: if request.auth != null && (
        resource.data.partner1Uid == request.auth.uid ||
        resource.data.partner2Uid == request.auth.uid
      );

      // Create: user must be setting themselves as partner1Uid
      allow create: if request.auth != null
        && request.resource.data.partner1Uid == request.auth.uid;

      // Update: existing member, OR a non-member filling an empty partner slot.
      // Both slots can be filled by a non-member because a disconnect can leave
      // either slot empty (not just partner2).
      allow update: if request.auth != null && (
        isMemberOfCouple(coupleId) ||
        (
          resource.data.get('partner2Uid', null) == null &&
          request.resource.data.partner2Uid == request.auth.uid
        ) ||
        (
          resource.data.get('partner1Uid', null) == null &&
          request.resource.data.partner1Uid == request.auth.uid
        )
      );

      // ── Blueprint results: both partners can READ, only owner can WRITE ─────
      match /blueprints/{userId} {
        allow read: if request.auth != null && isMemberOfCouple(coupleId);
        allow write: if request.auth != null
          && request.auth.uid == userId
          && isMemberOfCouple(coupleId);
      }

      // ── Time Capsules: metadata visible to both partners always, content gated ──
      // Metadata (sealedBy, sealedByName, openAt, opened, hasPhoto) is always
      // readable so the partner can see locked countdown. The actual message and
      // photo URL live in /sealed/data and are only readable AFTER openAt has
      // passed OR if the requester is the sealer themselves. This preserves the
      // core "1y / 5y / 10y sealed" promise even against a custom Firestore client.
      match /timeCapsules/{capsuleId} {
        allow read: if isMemberOfCouple(coupleId);
        allow create: if isMemberOfCouple(coupleId)
          && request.resource.data.sealedBy == request.auth.uid;
        allow update: if isMemberOfCouple(coupleId)
          && request.resource.data.sealedBy == resource.data.sealedBy;
        allow delete: if isMemberOfCouple(coupleId)
          && resource.data.sealedBy == request.auth.uid;

        match /sealed/{contentDoc} {
          // Sealer can always read their own content (UI shows preview while sealing).
          // Partner can read only AFTER the parent's openAt has passed.
          allow read: if isMemberOfCouple(coupleId) && (
            get(/databases/$(database)/documents/couples/$(coupleId)/timeCapsules/$(capsuleId)).data.sealedBy == request.auth.uid
            || get(/databases/$(database)/documents/couples/$(coupleId)/timeCapsules/$(capsuleId)).data.openAt <= request.time.toMillis()
          );
          allow create: if isMemberOfCouple(coupleId)
            && get(/databases/$(database)/documents/couples/$(coupleId)/timeCapsules/$(capsuleId)).data.sealedBy == request.auth.uid;
          // Content is immutable once sealed — that's the whole point.
          allow update: if false;
          allow delete: if isMemberOfCouple(coupleId)
            && get(/databases/$(database)/documents/couples/$(coupleId)/timeCapsules/$(capsuleId)).data.sealedBy == request.auth.uid;
        }
      }

      // ── Sunday Check-in: parent doc tracks completion, per-user answers gated ──
      // Parent doc (weekId metadata + completedAt map) is always readable so the
      // partner can see "they completed, waiting for me". Per-user answers live
      // in /entries/{uid} and are readable only by the owner OR by partner AFTER
      // both partners have completed. Prevents real-time peek at partner's draft.
      match /stateUnion/{weekId} {
        allow read: if isMemberOfCouple(coupleId);
        allow create, update: if isMemberOfCouple(coupleId);
        allow delete: if false;

        match /entries/{userId} {
          allow read: if isMemberOfCouple(coupleId) && (
            request.auth.uid == userId
            || (
              get(/databases/$(database)/documents/couples/$(coupleId)/stateUnion/$(weekId)).data.get('completedAt', {}).keys().hasAll([request.auth.uid, userId])
            )
          );
          allow create, update: if isMemberOfCouple(coupleId)
            && request.auth.uid == userId;
          allow delete: if false;
        }
      }

      // ── All other subcollections under a couple ────────────────────────────
      // Schema validation: prevent spoofing of identity fields.
      // Any document the caller creates with these fields MUST have them set to themselves.
      // Reads + updates + deletes remain available to either couple member.
      match /{subcollection}/{document=**} {
        allow read: if request.auth != null && isMemberOfCouple(coupleId);
        allow create: if request.auth != null
          && isMemberOfCouple(coupleId)
          && (!('fromUid'   in request.resource.data) || request.resource.data.fromUid   == request.auth.uid)
          && (!('createdBy' in request.resource.data) || request.resource.data.createdBy == request.auth.uid)
          && (!('loggedBy'  in request.resource.data) || request.resource.data.loggedBy  == request.auth.uid)
          && (!('sealedBy'  in request.resource.data) || request.resource.data.sealedBy  == request.auth.uid)
          && (!('uid'       in request.resource.data) || request.resource.data.uid       == request.auth.uid);
        // Updates: identity fields are immutable once set
        allow update: if request.auth != null
          && isMemberOfCouple(coupleId)
          && (!('fromUid'   in resource.data) || request.resource.data.fromUid   == resource.data.fromUid)
          && (!('createdBy' in resource.data) || request.resource.data.createdBy == resource.data.createdBy)
          && (!('loggedBy'  in resource.data) || request.resource.data.loggedBy  == resource.data.loggedBy)
          && (!('sealedBy'  in resource.data) || request.resource.data.sealedBy  == resource.data.sealedBy)
          && (!('uid'       in resource.data) || request.resource.data.uid       == resource.data.uid);
        allow delete: if request.auth != null && isMemberOfCouple(coupleId);
      }
    }
  }
}
